# Supabase project credentials — copy this file to .env and fill in your values
# Find these in your Supabase project dashboard under Settings > API

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# NOTE: SAP_SERVICE_LAYER_URL is a server-side secret set via:
#   supabase secrets set SAP_SERVICE_LAYER_URL=https://your-sap-server:50000
# It is NEVER placed in this file or exposed to the browser.
